{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "RadioSelenium (headless)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/RadioSelenium.py",
            "console": "integratedTerminal"
        },
        {
            "name": "RadioSelenium (--head, visible Firefox)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/RadioSelenium.py",
            "args": ["--head"],
            "console": "integratedTerminal"
        }
    ]
}